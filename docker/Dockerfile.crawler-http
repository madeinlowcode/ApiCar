FROM python:3.12-slim

WORKDIR /app

# No Playwright/Chromium needed — just Python + httpx + beautifulsoup4
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir ".[crawler-http]"

COPY shared/ ./shared/
COPY crawler/ ./crawler/
COPY run_crawl_http.py .
COPY run_crawl_brands.py .

CMD ["python", "run_crawl_http.py"]
